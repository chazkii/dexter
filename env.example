# LLM API Keys
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_API_KEY=your-google-api-key
XAI_API_KEY=your-xai-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
MOONSHOT_API_KEY=your-moonshot-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# Ollama (Local LLM & Cloud)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CLOUD_API_KEY=your-ollama-cloud-api-key

# Persistent memory embeddings reuse existing model API keys.
# Priority: OpenAI (OPENAI_API_KEY) -> Gemini (GOOGLE_API_KEY) -> Ollama (OLLAMA_BASE_URL)
# No additional memory-specific API keys required.

# Stock Market API Key (primary financial data source)
FINANCIAL_DATASETS_API_KEY=your-financial-datasets-api-key

# Alternative financial data sources (fallbacks)
# FMP (Financial Modeling Prep) — freemium, 250 calls/day on the free tier.
# Broad international coverage; used when Financial Datasets returns a premium-only
# error or lacks coverage. Free key: https://site.financialmodelingprep.com
FMP_API_KEY=your-fmp-api-key
# Yahoo Finance, Robinhood, CoinGecko (on-chain crypto), and FRED (US macro/rates)
# require NO API key. Optional: WHALE_ALERT_API_KEY enables multi-chain whale tracking
# in get_onchain_crypto (BTC works without it via blockchain.info).
# WHALE_ALERT_API_KEY=your-whale-alert-api-key

# Options chain (get_options_chain), BitMEX (bitmex_market), earnings transcripts
# (get_earnings_transcript — falls back to Tavily search if TAVILY_API_KEY is set),
# price_distribution_chart, and forecast_arbitrator require NO API key.
# social_sentiment is only registered when X_BEARER_TOKEN is set (see below).

# Web Search API Keys (Exa → Perplexity → Tavily → LangSearch)
EXASEARCH_API_KEY=your-exa-api-key
PERPLEXITY_API_KEY=your-perplexity-api-key
TAVILY_API_KEY=your-tavily-api-key
LANGSEARCH_API_KEY=your-langsearch-api-key

# X/Twitter API (enables x_search tool for public sentiment research)
X_BEARER_TOKEN=your-X-bearer-token

# LangSmith 
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=dexter
LANGSMITH_TRACING=false
